
# RaftLab Environment Configuration

# Path to the node configuration file
CONFIG_PATH=deployments/configs/local/node1.yaml

# Fiber management API bind address
API_ADDRESS=:8080

# Build information exposed by the management API
BUILD_VERSION=dev

# Optional override for the WAL file path
RAFT_WAL_PATH=

# Optional override for the persistent metadata file path
RAFT_METADATA_PATH=

# Optional override for the snapshot directory
RAFT_SNAPSHOT_DIR=
